# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Groq API key (used only to translate grounded facts into Bangla + summaries)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of allowed frontend origins for CORS.
# Example: https://fasal-doctor.vercel.app,http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Optional: minimum softmax confidence before we name a disease (default 0.55)
FASAL_CONF_THRESHOLD=0.55
